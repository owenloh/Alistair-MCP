# =============================================================================
# Alistair Skills API — environment variables
# Copy to .env for local dev:  cp .env.example .env   (then fill in real values)
# On Railway, set these in the service "Variables" tab. NEVER commit real values.
# =============================================================================

# ---- User / personalisation -------------------------------------------------
# Who this assistant works for. Used to personalise every user-facing string
# (persona, tool descriptions, skills). The code ships with NO name hardcoded —
# set yours here. Defaults to a neutral "the user" if left blank.
USER_NAME=

# ---- Service ----------------------------------------------------------------
# Set to "production" on Railway. Anything else is treated as dev.
RAILWAY_ENV=development
# Optional: if set, every /api/* request must send header  X-API-Key: <this>
# Leave blank to run the API open (fine for first smoke tests; set it before
# pointing anything real at the public URL — these endpoints expose private data).
SERVICE_API_KEY=

# ---- Notion (POST /api/notion/query) ----------------------------------------
# Internal integration secret (starts with ntn_ or secret_). Read access is enough.
# Share the Projects AND Actions databases with the integration in Notion.
NOTION_TOKEN=
# YOUR OWN Notion ids (nothing is hardcoded). Database ids are the 32-char REST ids
# from the database URL. Leave any blank to disable the feature that needs it.
PROJECTS_DB_ID=
ACTIONS_DB_ID=
# Page ids the assistant writes to / references (from each page's Notion URL):
#  * REFERENCES_TRAY_PAGE_ID — the page save_reference appends entries to.
#  * LIBRARY_HUB_PAGE_ID      — the tray's parent hub (referenced, never written).
#  * BRIEFING_PAGE_ID         — the page the daily brief writes to.
REFERENCES_TRAY_PAGE_ID=
LIBRARY_HUB_PAGE_ID=
BRIEFING_PAGE_ID=
NOTION_VERSION=2022-06-28
# ---- Notion workspace layout (GTD/PARA) -------------------------------------
# The skill instructions describe a generic Areas -> Projects -> Actions layout;
# only these ids pin it to YOUR workspace. All optional — set the ones you use.
# Collection ids (Notion's `collection://` schema ids) for each database:
AREAS_COLLECTION_ID=
PROJECTS_COLLECTION_ID=
ACTIONS_COLLECTION_ID=
# The Briefing page's parent page:
MISSION_CONTROL_PAGE_ID=
# Saved-view ids (Notion's `view://` filtered lists) the daily/weekly brief reads:
VIEW_PROJECTS_ACTIVE_ID=
VIEW_PROJECTS_SOMEDAY_ID=
VIEW_PROJECTS_ALL_ID=
VIEW_ACTIONS_NEXT_ID=
VIEW_ACTIONS_NP_NEXT_ID=
VIEW_ACTIONS_WAITING_ID=
VIEW_ACTIONS_SOMEDAY_ID=
VIEW_ACTIONS_ALL_ID=

# ---- Google Calendar + Gmail (POST /api/calendar/* and /api/gmail/*) ---------
# Durable path (RECOMMENDED): an OAuth "Desktop app" client + a refresh token
# minted once via scripts/get_google_token.py. If all three are set, the service
# mints a fresh access token on every call, so it never goes stale.
# Scopes: .../auth/calendar (Calendar read+write); for Gmail read+draft also add
# gmail.readonly + gmail.compose. Publish the OAuth app to Production, else the
# refresh token expires after 7 days.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Which calendar to use. "primary" = the account's main calendar.
GOOGLE_CALENDAR_ID=primary
# Home / fallback IANA timezone (CALENDAR_TIMEZONE also accepted as an alias).
# Defaults to UTC in code (no location baked in) — set your own, e.g. Europe/London.
TIMEZONE=
# Follow travel: auto-detect your CURRENT Google Calendar timezone on each call,
# falling back to TIMEZONE above. A per-call timeZone arg always overrides.
# Set to false to always pin TIMEZONE.
TIMEZONE_AUTO=true
# Optional fallback ONLY: a current OAuth access token (Bearer). Not needed when
# the three vars above are set — leave blank when using the refresh-token flow.
GOOGLE_CALENDAR_TOKEN=

# ---- Microsoft To Do in-tray (POST /api/intray) -----------------------------
# Azure app (client) id — public client, "Allow public client flows" = Yes.
MS_CLIENT_ID=
# The single To Do list id used as the in-tray (hard scope).
MS_TODO_LIST_ID=
# "consumers" for personal MS accounts, "common" for work/school.
MS_TENANT=consumers
# The MS refresh token is stored in a private GitHub gist and self-rolls.
# GITHUB_GIST_TOKEN: classic PAT with the "gist" scope (old name GITHUB_TOKEN still works as an alias).
GITHUB_GIST_TOKEN=
# GIST_ID: id of the private gist holding the refresh token.
GIST_ID=
# Filename inside the gist that holds the refresh token.
GIST_FILENAME=mstodo_refresh_token

# ---- GitHub repo read + PR (POST /api/github/* and the MCP github_* tools) ---
# Token for the read tools (whoami, list-my-repos, get-file, list-tree,
# recent-commits, list-prs, list-issues, get-pr, search-code) and the guarded
# merge-pr. Kept DISTINCT from GITHUB_GIST_TOKEN above; if this is unset, the gist
# token is used as a fallback.
#   * Account-aware tools (whoami, list-my-repos) report the account this token
#     belongs to and enumerate exactly the repos it can reach — public AND private.
#   * Scope is the token's: a fine-grained PAT only sees the repos/orgs you grant
#     it; a classic PAT with the 'repo' scope sees every repo the owning account can.
GITHUB_REPO_TOKEN=

# ---- Spotify (unofficial, via SpotAPI — POST /api/spotify/* + the spotify_* tools)
# No Spotify Developer app or official OAuth needed: this drives Spotify the way
# the web player does, so it just needs a logged-in browser session.
# How to get the cookies (the durable, no-CAPTCHA path):
#   1. Log in to https://open.spotify.com in a browser.
#   2. DevTools (F12) -> Application/Storage -> Cookies -> https://open.spotify.com
#   3. Copy the cookies. SPOTIFY_COOKIES accepts EITHER a raw cookie string
#      "sp_dc=...; sp_key=...; sp_t=..." OR a JSON object {"sp_dc":"...","sp_key":"..."}.
#      At minimum include sp_dc (auth). Cookies expire — refresh if calls start 401ing.
SPOTIFY_COOKIES=
# The account's email or username (labels the session).
SPOTIFY_USERNAME=
# Optional: only needed if you choose password login (which also needs a CAPTCHA
# solver). Leave blank when using cookies.
SPOTIFY_PASSWORD=
# NOTE: playback control (devices, play, pause, transfer) uses Spotify Connect, so
# Spotify must be OPEN/active on at least one device (phone/desktop/web player) for
# those to work. Browsing playlists and searching work without an active device.

# ---- WhatsApp (read via a laptop agent + draft via wa.me links; POST /api/whatsapp/*)
# READ + DRAFT only — Alistair NEVER sends a WhatsApp message.
#  * Reading proxies to a SEPARATE laptop read-agent (Baileys, its own linked
#    device; lives in its own repo), reachable over Tailscale. Online-only: if the
#    laptop is off the read tools report "offline". The MCP stores nothing.
#  * Drafting builds a wa.me deep link you tap to open WhatsApp with the text
#    pre-filled — it needs NEITHER of these vars (drafting always works).
# Base URL of the laptop read-agent (e.g. a Tailscale Funnel/tailnet URL). Leave blank
# to disable reading (drafting still works).
WHATSAPP_AGENT_URL=
# Shared bearer secret — must match AGENT_SECRET in whatsapp-agent/.env.
WHATSAPP_AGENT_SECRET=
# Country code for internationalising BARE LOCAL numbers (e.g. UK 07700… -> 447700…).
# Blank = no country baked in; enter full international numbers, or set this (e.g. 44).
WHATSAPP_DEFAULT_COUNTRY_CODE=
